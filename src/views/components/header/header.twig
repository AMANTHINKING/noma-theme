<header id="mainnav" class="site-header">
  <div class="container site-header__inner inner">
    <a class="brand" href="{{ store.url }}">
      <img src="{{ 'images/noma-logo-mark.jpg' | asset }}" alt="{{ store.name }} logo">
      <span class="brand__wordmark">
        <span class="brand__name">NOMA.</span>
        <span class="brand__tag">Screen Comfort+</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href="{{ store.url }}">Home</a>
      <a href="{{ store.url ~ '/products' }}">Shop</a>
      <a href="{{ store.url ~ '/page/choose' }}">How to Choose</a>
      <a href="{{ store.url ~ '/page/about' }}">About NOMA</a>
    </nav>

    <div class="site-actions">
      <salla-search inline oval height="44"></salla-search>
      <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
      <salla-cart-summary class="site-cart">
        <i slot="icon" class="sicon-shopping-bag"></i>
      </salla-cart-summary>
    </div>
  </div>
</header>
