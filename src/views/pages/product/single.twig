{% extends "layouts.master" %}

{% block content %}
  <section class="section">
    <div class="container">
      <nav class="breadcrumbs breadcrumbs--noma">
        <salla-breadcrumb></salla-breadcrumb>
      </nav>

      <div class="product-layout">
        <div class="product-media">
          {% set hero_image = product.image.url|default(product.images|first.url|default('images/noma-lenses-overview.jpg'|asset)) %}
          <img src="{{ hero_image }}" alt="{{ product.name }}">
        </div>

        <div class="product-side-grid">
          <div>
            <p class="eyebrow">Product Page</p>
            <h1 class="product-title">{{ product.name }}</h1>
            {% if product.subtitle %}
              <p class="product-copy">{{ product.subtitle }}</p>
            {% endif %}
            <div class="product-price-line">
              {% if product.is_on_sale %}
                <strong>{{ product.sale_price|money }}</strong>
                <span>{{ product.regular_price|money }}</span>
              {% else %}
                <strong>{{ product.starting_price ? product.starting_price|money : product.price|money }}</strong>
              {% endif %}
            </div>

            <ul class="product-bullets">
              <li>Built for gamers, professionals, students, and heavy screen users</li>
              <li>Minimal explanation blocks that reduce friction before checkout</li>
              <li>Presented as a wellness tool, not generic eyewear</li>
            </ul>
          </div>

          <section class="lens-selector" aria-labelledby="lens-selector-title">
            <p class="eyebrow">Choose Lens</p>
            <h2 id="lens-selector-title">Pick the right filter level</h2>

            <div class="lens-options" role="tablist" aria-label="Lens options">
              <button class="lens-option" type="button" data-lens-option data-name="CLEAR" data-tone="Transparent" data-time="Day / Work / Study" data-level="Low" data-description="Reduces eye strain without changing how colors look." data-usage="Best for office work, studying, and gaming during the day.">
                <span class="lens-option__name">CLEAR</span>
                <span class="lens-option__meta">Transparent • Daytime</span>
              </button>
              <button class="lens-option" type="button" data-lens-option data-name="EVENING" data-tone="Soft Yellow" data-time="After sunset" data-level="Medium" data-description="Gradually lowers blue-light exposure during evening hours." data-usage="Best after sunset, during casual screen time, or late work sessions.">
                <span class="lens-option__name">EVENING</span>
                <span class="lens-option__meta">Yellow • Evening</span>
              </button>
              <button class="lens-option" type="button" data-lens-option data-name="NIGHT" data-tone="Orange" data-time="Before sleep" data-level="High" data-description="Stronger filtering intended for the final hours before bed." data-usage="Best before sleep when customers want a stronger nighttime routine.">
                <span class="lens-option__name">NIGHT</span>
                <span class="lens-option__meta">Orange • Pre-sleep</span>
              </button>
              <button class="lens-option" type="button" data-lens-option data-name="MAX" data-tone="Deep Red" data-time="Late night / Maximum protection" data-level="Maximum" data-description="Highest filtering level for intense nighttime blue-light protection." data-usage="Best for users staying up very late or wanting the strongest filter level.">
                <span class="lens-option__name">MAX</span>
                <span class="lens-option__meta">Red • Maximum</span>
              </button>
            </div>
          </section>

          <section class="usage-panel" data-lens-display aria-live="polite">
            <p class="eyebrow">Lens Details</p>
            <h3><span data-name>CLEAR</span> lens overview</h3>
            <p data-description>Reduces eye strain without changing how colors look.</p>

            <div class="use-grid" style="margin-top:18px;">
              <div class="use-card">
                <strong>Color</strong>
                <p data-tone>Transparent</p>
              </div>
              <div class="use-card">
                <strong>Use Time</strong>
                <p data-time>Day / Work / Study</p>
              </div>
              <div class="use-card">
                <strong>Blocking</strong>
                <p data-level>Low</p>
              </div>
            </div>

            <div class="use-card" style="margin-top:18px;">
              <strong>When to use this lens</strong>
              <p data-usage>Best for office work, studying, and gaming during the day.</p>
            </div>
          </section>

          <form class="form product-form purchase-panel" enctype="multipart/form-data" method="post"
                onsubmit="return salla.form.onSubmit('cart.addItem', event)">
            <input type="hidden" name="id" value="{{ product.id }}">

            {% hook 'product:single.form.start' %}
            {% include 'pages.partials.product.options' %}
            {% hook 'product:single.form.end' %}

            <div class="purchase-panel__row">
              {% if product.is_hidden_quantity or product.type == 'booking' %}
                <input type="hidden" value="1" name="quantity" aria-label="Quantity">
              {% else %}
                <div class="purchase-panel__quantity">
                  <label class="purchase-panel__label">{{ trans('pages.products.quantity') }}</label>
                  <salla-quantity-input max="{{ product.max_quantity }}" value="1" name="quantity" aria-label="Quantity"></salla-quantity-input>
                </div>
              {% endif %}
            </div>

            <salla-add-product-button
              {{ product.can_quick_buy ? 'quick-buy' : '' }}
              {{ product.is_require_shipping ? 'required-shipping' : '' }}
              amount="{{ product.base_currency_price }}"
              class="button button--primary purchase-panel__button"
              product-status="{{ product.status }}"
              product-type="{{ product.type }}"
              product-id="{{ product.id }}"
              loader-position="end"
              type="submit"
              width="wide">
              {{ product.add_to_cart_label }}
            </salla-add-product-button>
          </form>

          <section class="review-panel">
            <p class="eyebrow">Reviews</p>
            <h3>Placeholder section ready for customer proof.</h3>
            <strong>“Comfortable for long work sessions and much easier on the eyes at night.”</strong>
            <small>Add native Salla reviews, testimonial cards, or imported proof once the store is live.</small>
          </section>
        </div>
      </div>
    </div>
  </section>
{% endblock %}
